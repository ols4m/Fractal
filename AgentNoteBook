## Original LLM Backend Strategy (FastAPI + Groq/Ollama)

*(Original AgentNotebook content preserved below)*

---

### Goal
Use an LLM to generate structured domain nodes, suggest tensions, and create 1 emergent grey synthesis. You control the structure.

### LLM Prompt Schema
```json
{
  "domains": [{"name": "", "summary": ""}],
  "tensions": [{"source": "", "target": "", "relationship": ""}],
  "emergent_pattern": {"label": "", "summary": ""}
}
```

### FastAPI Endpoint (swap OpenAI for Groq)
```python
from fastapi import FastAPI
from pydantic import BaseModel
import httpx
import os
import json

GROQ_API_KEY = os.getenv("GROQ_API_KEY")
GROQ_API_URL = "https://api.groq.com/openai/v1/chat/completions"
MODEL = "llama3-8b-8192"
TEMPERATURE = 0.3

# For local dev with Ollama, swap these:
# GROQ_API_URL = "http://localhost:11434/api/chat"
# MODEL = "llama3"

DEMO_MODE = {
    "nodes": [
        {"name": "Demo Domain A", "summary": "Example summary A", "color": "blue"},
        {"name": "Demo Domain B", "summary": "Example summary B", "color": "green"},
        {"name": "Emergent Pattern", "summary": "Grey synthesis demo", "color": "grey"},
    ],
    "edges": [
        {"source": "Demo Domain A", "target": "Demo Domain B", "relationship": "tension"}
    ]
}

app = FastAPI()

class MapRequest(BaseModel):
    query: str

def validate_llm_output(output_json):
    try:
        domains = output_json.get("domains", [])
        emergent = output_json.get("emergent_pattern", {})
        if not (3 <= len(domains) <= 5): return False
        if not emergent.get("summary"): return False
        for d in domains:
            if not d.get("summary") or not d.get("name"): return False
        return True
    except Exception:
        return False

def transform_to_graph(output_json):
    nodes = []
    edges = []
    for d in output_json["domains"]:
        nodes.append({"name": d["name"], "summary": d["summary"], "color": "blue"})
    ep = output_json["emergent_pattern"]
    nodes.append({"name": ep["label"], "summary": ep["summary"], "color": "grey"})
    for t in output_json.get("tensions", []):
        edges.append({"source": t["source"], "target": t["target"], "relationship": t["relationship"]})
    return {"nodes": nodes, "edges": edges}

@app.post("/generate-map")
async def generate_map(request: MapRequest):
    try:
        prompt = f"""
You are generating a structured research field map for Fractal.
Return JSON only. No prose. No explanations.

{{
  "domains": [{{"name": "", "summary": ""}}],
  "tensions": [{{"source": "", "target": "", "relationship": ""}}],
  "emergent_pattern": {{"label": "", "summary": ""}}
}}

Rules:
- 3-5 domains only
- At least 1 emergent pattern
- No empty summaries
- Avoid buzzwords
- Focus on structural forces and real tensions
- JSON only

Query: {request.query}
"""
        async with httpx.AsyncClient() as client:
            response = await client.post(
                GROQ_API_URL,
                headers={"Authorization": f"Bearer {GROQ_API_KEY}"},
                json={
                    "model": MODEL,
                    "messages": [{"role": "user", "content": prompt}],
                    "temperature": TEMPERATURE
                }
            )
        content = response.json()["choices"][0]["message"]["content"]
        output_json = json.loads(content)
        if not validate_llm_output(output_json):
            return DEMO_MODE
        return transform_to_graph(output_json)
    except Exception as e:
        print("Error:", e)
        return DEMO_MODE
```

